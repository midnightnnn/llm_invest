# Core
GOOGLE_CLOUD_PROJECT=your-gcp-project-id
BQ_DATASET=llm_arena
BQ_LOCATION=asia-northeast3

# Arena
ARENA_AGENT_IDS=gemini,gpt,claude
ARENA_AGENT_MODE=adk
ARENA_TENANT_ID=local
ARENA_BASE_CURRENCY=KRW
ARENA_SLEEVE_CAPITAL_KRW=1000000
# One-time cleanup: set true for a single run to reset every agent sleeve baseline.
ARENA_FORCE_SLEEVE_REINIT=false
ARENA_SLEEVE_BOOTSTRAP_FROM_ACCOUNT=false
ARENA_LOG_LEVEL=INFO
ARENA_LOG_FORMAT=rich
ARENA_UNIVERSE_RUN_TOP_N=400
ARENA_UNIVERSE_PER_EXCHANGE_CAP=200
ARENA_US_QUOTE_EXCHANGES=NAS,NYS

# LLM
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.2
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6
ANTHROPIC_USE_VERTEXAI=false
# Gemini backend:
# - API key mode (Google AI Studio): set GEMINI_API_KEY
# - Vertex AI mode (recommended on GCP): set GOOGLE_GENAI_USE_VERTEXAI=true and GOOGLE_CLOUD_LOCATION=global
# GOOGLE_GENAI_USE_VERTEXAI=true
# GOOGLE_CLOUD_LOCATION=global
GEMINI_API_KEY=
GEMINI_MODEL=gemini-3-flash-preview
ARENA_LLM_TIMEOUT_SECONDS=90
# Role-specific overrides (leave empty to inherit ARENA_LLM_TIMEOUT_SECONDS).
# Trading agents do deep reasoning (Claude effort=xhigh/max, thinking=adaptive)
# so they need a long budget. Research/compaction are fast lookups — keep short
# so a single stuck call cannot block the whole cycle.
ARENA_LLM_TIMEOUT_TRADING_SECONDS=3000
ARENA_LLM_TIMEOUT_RESEARCH_SECONDS=90
ARENA_LLM_TIMEOUT_COMPACTION_SECONDS=300
ARENA_ADK_RETRY_MAX=2
ARENA_ADK_RETRY_BACKOFF_SECONDS=2.0

# Trading mode: paper | live
ARENA_TRADING_MODE=paper
ARENA_ALLOW_LIVE_TRADING=false

# UI auth (local Google login)
ARENA_UI_AUTH_ENABLED=false
# Optional public demo tenant. When set and the tenant exists, signed-in users
# are auto-granted viewer access to this tenant (for example: midnightnnn).
ARENA_PUBLIC_DEMO_TENANT=
# Optional: approved live/private tenants can borrow research-only Gemini
# from this operator tenant. This does not enable Gemini trading agents.
ARENA_SHARED_RESEARCH_GEMINI_SOURCE_TENANT=
# Operator emails for /ops monitoring page (comma-separated)
ARENA_OPERATOR_EMAILS=
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
ARENA_UI_GOOGLE_REDIRECT_URI=http://127.0.0.1:8080/auth/google/callback
ARENA_UI_SESSION_SECRET=change-me-for-local-dev

# KIS execution source
# If KIS_ORDER_ENDPOINT is set, live mode uses that HTTP bridge.
# If empty, live mode directly calls open-trading API.
KIS_ORDER_ENDPOINT=

# KIS auth/account (optional when using Secret Manager)
KIS_API_KEY=
KIS_API_SECRET=
KIS_PAPER_API_KEY=
KIS_PAPER_API_SECRET=
KIS_ACCOUNT_NO=
KIS_ACCOUNT_PRODUCT_CODE=01
KIS_ACCOUNT_KEY_SUFFIX=
KIS_ENV=real

# Secret Manager override (recommended)
KIS_SECRET_NAME=KISAPI
KIS_SECRET_VERSION=latest

# KIS HTTP behavior
KIS_TOKEN_CACHE_BACKEND=memory  # or firestore (recommended on Cloud Run)
KIS_HTTP_TIMEOUT_SECONDS=20
KIS_HTTP_MAX_RETRIES=3
KIS_HTTP_BACKOFF_BASE_SECONDS=0.8
KIS_HTTP_BACKOFF_MAX_SECONDS=8.0

# Optional: best-effort fill confirmation polling
KIS_CONFIRM_FILLS=false
KIS_CONFIRM_TIMEOUT_SECONDS=25
KIS_CONFIRM_POLL_SECONDS=2.0

# Optional: live order slippage model (bps)
ARENA_LIVE_SLIPPAGE_BPS_BASE=8
ARENA_LIVE_SLIPPAGE_BPS_IMPACT=12
ARENA_LIVE_SLIPPAGE_BPS_MAX=80

# Market target: nasdaq | nyse | amex | us | kospi
KIS_TARGET_MARKET=us
KIS_OVERSEAS_QUOTE_EXCD=NAS
KIS_OVERSEAS_ORDER_EXCD=NASD
KIS_US_NATN_CD=840
KIS_US_TR_MKET_CD=01
ARENA_USD_KRW_RATE=1300
ARENA_USD_KRW_FX_SYMBOL=
ARENA_USD_KRW_FX_MARKET_DIV_CODE=X
ARENA_MARKET_SYNC_HISTORY_DAYS=60
ARENA_NASDAQ_CYCLE_TIMES_ET=15:30
ARENA_NASDAQ_CYCLE_TOLERANCE_MINUTES=20
ARENA_NASDAQ_DISABLE_SCHEDULE_GUARD=false

# Risk
ARENA_MAX_ORDER_KRW=350000
ARENA_MAX_DAILY_TURNOVER_RATIO=0.65
ARENA_MAX_POSITION_RATIO=0.35
ARENA_MIN_CASH_BUFFER_RATIO=0.10
ARENA_TICKER_COOLDOWN_SECONDS=120

# Context
ARENA_CONTEXT_MAX_BOARD_POSTS=24
ARENA_CONTEXT_MAX_MEMORY_EVENTS=32
ARENA_CONTEXT_MAX_MARKET_ROWS=64

# Forecast
# all: base + stacked rows together, stacked: meta rows only, base: base-model rows only
ARENA_FORECAST_MODE=all
# neural: NBEATSx/NHITS/PatchTST/iTransformer only, all: neural + foundation models
ARENA_FORECAST_BASE_MODELS=neural

# FRED (US macro indicators)
FRED_API_KEY=
# ECOS (Korean macro indicators - 한국은행 경제통계시스템)
ECOS_API_KEY=
