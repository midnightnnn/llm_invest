<div data-kis-row class="rounded-xl border border-ink-200/70 bg-white/70 p-4 space-y-2">
  <div class="flex items-center justify-between gap-3">
    <p class="text-[11px] font-bold uppercase tracking-widest text-ink-500">{{ row.account_no_display }}</p>
    {% if row.is_active %}<span class="inline-flex items-center rounded-full bg-emerald-100 px-2 py-0.5 text-[10px] font-bold tracking-wide text-emerald-700">현재 사용 중</span>{% endif %}
  </div>
  <div class="grid gap-2 sm:grid-cols-2">
    <label class="text-sm text-ink-700">ENV<select data-field="env" class="mt-1 w-full rounded-xl border border-ink-200 bg-white px-3 py-2 text-ink-900">{% if row.allow_real_kis_credentials %}<option value="real" {% if row.real_selected %}selected{% endif %}>real</option><option value="demo" {% if row.demo_selected %}selected{% endif %}>demo</option>{% else %}<option value="demo" {% if row.demo_selected %}selected{% endif %}>demo</option>{% endif %}</select></label>
    <label class="text-sm text-ink-700">ACCOUNT NO<input data-field="account_no" value="{{ row.account_no }}" class="mt-1 w-full rounded-xl border border-ink-200 bg-white px-3 py-2 text-ink-900" placeholder="12345678-01"/></label>
  </div>
  {% if row.allow_real_kis_credentials %}
    {% for field in row.real_fields %}
      <label class="text-sm text-ink-700 block">{{ field.label }}{% if field.masked %}<p class="mt-1 text-[11px] text-ink-500"><span class="inline-block max-w-full align-bottom truncate" title="{{ field.masked_full }}">저장됨: {{ field.masked_compact }}</span></p>{% else %}<p class="mt-1 text-[11px] text-ink-400">저장된 키 없음</p>{% endif %}<input data-field="{{ field.name }}" type="password" class="mt-1 w-full rounded-xl border border-ink-200 bg-white px-3 py-2 text-ink-900" placeholder="변경 시 입력" autocomplete="off"/></label>
    {% endfor %}
  {% endif %}
  {% if row.allow_paper_kis_credentials %}
    {% for field in row.paper_fields %}
      <label class="text-sm text-ink-700 block">{{ field.label }}{% if field.masked %}<p class="mt-1 text-[11px] text-ink-500"><span class="inline-block max-w-full align-bottom truncate" title="{{ field.masked_full }}">저장됨: {{ field.masked_compact }}</span></p>{% else %}<p class="mt-1 text-[11px] text-ink-400">저장된 키 없음</p>{% endif %}<input data-field="{{ field.name }}" type="password" class="mt-1 w-full rounded-xl border border-ink-200 bg-white px-3 py-2 text-ink-900" placeholder="변경 시 입력" autocomplete="off"/></label>
    {% endfor %}
  {% endif %}
  <div class="flex justify-end"><button type="button" data-kis-remove class="rounded-lg border border-red-200 bg-red-50 px-3 py-1.5 text-xs font-semibold text-red-700 hover:bg-red-100">Remove</button></div>
</div>
