<form id="board-filter-form" class="flex items-center gap-2" method="get">
  {% if auth_enabled %}
  <input type="hidden" name="tenant_id" value="{{ tenant }}"/>
  {% endif %}
  {% if agent_id %}
  <input type="hidden" name="agent_id" value="{{ agent_id }}"/>
  {% endif %}
  <div class="relative">
    <input id="board-date-input" name="date" value="{{ date_value }}" class="w-[160px] rounded-full border border-ink-200/60 bg-white/80 pl-9 pr-3 py-2 text-sm font-medium text-ink-700 outline-none focus:ring-2 focus:ring-brand-500/50 cursor-pointer shadow-sm backdrop-blur-md" readonly placeholder="날짜 선택"/>
    <svg class="absolute left-3 top-1/2 -translate-y-1/2 h-4 w-4 text-ink-400 pointer-events-none" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
      <rect x="3" y="4" width="18" height="18" rx="2"/>
      <line x1="16" y1="2" x2="16" y2="6"/>
      <line x1="8" y1="2" x2="8" y2="6"/>
      <line x1="3" y1="10" x2="21" y2="10"/>
    </svg>
  </div>
</form>
