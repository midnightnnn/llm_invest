{% if popup_text %}
<script>(function(){
const level={{ popup_level|tojson }};
const message={{ popup_text|tojson }};
if(!message){return;}
const toast=document.createElement('div');
toast.setAttribute('role','status');
toast.style.position='fixed';
toast.style.right='16px';
toast.style.top='16px';
toast.style.zIndex='9999';
toast.style.maxWidth='420px';
toast.style.padding='12px 14px';
toast.style.borderRadius='12px';
toast.style.border='1px solid';
toast.style.boxShadow='0 10px 24px rgba(15,23,42,0.15)';
toast.style.backdropFilter='blur(6px)';
toast.style.fontSize='13px';
toast.style.fontWeight='600';
toast.style.transition='opacity .25s ease, transform .25s ease';
toast.style.opacity='0';
toast.style.transform='translateY(-6px)';
if(level==='success'){
  toast.style.background='rgba(236,253,245,0.95)';
  toast.style.borderColor='rgba(16,185,129,0.35)';
  toast.style.color='#065f46';
}else{
  toast.style.background='rgba(254,242,242,0.96)';
  toast.style.borderColor='rgba(239,68,68,0.35)';
  toast.style.color='#991b1b';
}
toast.textContent=message;
document.body.appendChild(toast);
requestAnimationFrame(function(){
  toast.style.opacity='1';
  toast.style.transform='translateY(0)';
});
setTimeout(function(){
  toast.style.opacity='0';
  toast.style.transform='translateY(-6px)';
  setTimeout(function(){toast.remove();},250);
},3200);
})();</script>
{% endif %}

{% if credential_store_error %}
<section class="mt-4 reveal rounded-2xl border border-amber-200 bg-amber-50 p-4 text-sm text-amber-900">
  Secret Manager client unavailable: {{ credential_store_error }}
</section>
{% endif %}

{% if not auth_enabled %}
<section class="mt-2 reveal rounded-[20px] border border-ink-200/40 bg-white/80 p-4 shadow-[0_2px_12px_rgba(15,23,42,0.03)] backdrop-blur-md">
  <form class="grid gap-3 sm:grid-cols-4" method="get" action="/settings">
    <label class="text-sm text-ink-700 sm:col-span-2">
      tenant_id
      <input name="tenant_id" value="{{ tenant }}" class="mt-1 w-full rounded-xl border border-ink-200 bg-white px-3 py-2"/>
    </label>
    <div class="sm:col-span-2 flex items-end">
      <button class="rounded-xl bg-ink-900 px-4 py-2 text-sm font-medium text-white hover:bg-ink-700" type="submit">Switch Tenant</button>
    </div>
  </form>
</section>
{% endif %}

<section class="mt-2 reveal">
  <div class="min-w-0">
    {# Server-side: only render panels for the active tab #}
    {% if initial_tab == 'agents' %}
      {{ credentials_panel|safe }}
      {{ agents_panel|safe }}
    {% elif initial_tab == 'capital' %}
      {{ capital_panel|safe }}
    {% elif initial_tab == 'mcp' %}
      {{ mcp_panel|safe }}
    {% elif initial_tab == 'memory' %}
      {{ memory_panel|safe }}
    {% else %}
      {{ credentials_panel|safe }}
      {{ agents_panel|safe }}
    {% endif %}
  </div>
</section>
{{ tab_script|safe }}
{{ save_progress_script|safe }}
{% if showcase %}
<style>
  input:not([type="hidden"]),
  select,
  textarea { pointer-events: none !important; opacity: 0.65 !important; }
  button[type="submit"] { pointer-events: none !important; opacity: 0.45 !important; }
  .toggle-switch input { pointer-events: none !important; opacity: 0.45 !important; }
  .agent-tool-toggle { pointer-events: none !important; opacity: 0.5 !important; }
  [data-mcp-add] { pointer-events: none !important; opacity: 0.45 !important; }
</style>
<script>
document.addEventListener('DOMContentLoaded',function(){
  document.querySelectorAll('form[method="post"]').forEach(function(f){
    f.addEventListener('submit',function(e){e.preventDefault();e.stopImmediatePropagation();},true);
  });
});
</script>
{% endif %}
