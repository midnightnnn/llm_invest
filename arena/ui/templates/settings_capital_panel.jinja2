<div data-settings-panel="capital" class="hidden space-y-5">
  <form id="capitalDefaultForm" method="post" action="/admin/sleeve" class="hidden">
    <input type="hidden" name="tenant_id" value="{{ tenant }}" />
    <input type="hidden" name="updated_by" value="{{ updated_by }}" />
    <input type="hidden" name="sleeve_capital_krw" id="capitalDefaultHidden" value="{{ sleeve_capital_krw }}" />
    <input type="hidden" name="agent_capitals_json" id="capitalAgentsHidden" value="" />
  </form>
  <div class="relative overflow-hidden rounded-[24px] border border-ink-200/40 bg-[linear-gradient(180deg,_rgba(255,255,255,0.98),_rgba(248,250,252,0.96)_40%,_rgba(241,245,249,0.92))] p-6 shadow-[0_12px_40px_rgba(15,23,42,0.04),0_2px_6px_rgba(15,23,42,0.02)]">
    <div class="pointer-events-none absolute inset-x-0 top-0 h-44 bg-[radial-gradient(ellipse_at_top_right,_rgba(148,163,184,0.1),_transparent_60%)]"></div>
    <div class="relative flex flex-col gap-3 lg:flex-row lg:items-start lg:justify-between">
      <div>
        <p class="text-[10px] font-semibold uppercase tracking-[0.24em] text-ink-400/70">Capital Ledger</p>
        <h4 class="mt-1 text-lg font-bold text-ink-900 tracking-tight">에이전트별 장부 계보</h4>
        <p class="mt-1 text-xs text-ink-500/60 leading-relaxed">설정 자본금, checkpoint seed, 자본 이벤트, 이체·보정, 현재 NAV를 같은 탭에서 이어서 봅니다.</p>
      </div>
      <div class="flex flex-wrap items-center gap-1.5 rounded-xl border border-ink-200/30 bg-white/60 px-2 py-1.5 backdrop-blur-sm">{% for agent_id in agent_ids -%}
        <button type="button" data-capital-agent="{{ agent_id }}" class="capital-agent-tab rounded-lg border border-ink-200/40 bg-white/80 px-3.5 py-1.5 text-[11px] font-semibold tracking-wide text-ink-600 transition-all duration-200 hover:-translate-y-px hover:bg-white hover:shadow-sm">{{ agent_id }}</button>
      {%- endfor %}<form method="post" action="/admin/recover" class="inline-flex"><input type="hidden" name="tenant_id" value="{{ tenant }}" /><input type="hidden" name="updated_by" value="{{ updated_by }}" /><input type="hidden" name="live" value="{{ '1' if is_live else '0' }}" /><button type="submit" class="rounded-lg border border-amber-200/60 bg-amber-50/80 px-3 py-1.5 text-[11px] font-semibold text-amber-800 transition-all duration-200 hover:bg-amber-100/80 hover:-translate-y-px">Recover &amp; Reconcile</button></form></div>
    </div>
    <div id="capitalAgentConfig" class="relative mt-5">{{ spinner_html|safe }}</div>
    <div id="capitalHoldingsChart" class="hidden"></div>
    <div id="capitalLineageGraph" class="relative mt-5 min-h-[400px] rounded-[20px] border border-ink-200/30 bg-[radial-gradient(ellipse_at_top_left,_rgba(255,255,255,0.99),_rgba(248,250,252,0.96)_45%,_rgba(241,245,249,0.9))] p-5 shadow-[0_6px_28px_rgba(15,23,42,0.04)]">{{ spinner_html|safe }}</div>
    <div id="capitalLineageSummary" class="mt-5">{{ spinner_html|safe }}</div>
    <div class="mt-5 rounded-[20px] border border-ink-200/30 bg-white/90 p-5 shadow-[0_2px_16px_rgba(15,23,42,0.02)]">
      <div class="flex items-center justify-between gap-3">
        <div>
          <p class="text-[10px] font-semibold uppercase tracking-[0.2em] text-ink-400/70">Ledger Journal</p>
          <h5 class="mt-1 text-sm font-bold text-ink-900 tracking-tight">장부 이벤트 로그</h5>
          <p class="mt-1 text-[11px] text-ink-500/60 leading-relaxed">시드 원금과 이후 자본 이벤트를 누적 기준 원금 기준으로 나열합니다.</p>
        </div>
        <div id="capitalLedgerMeta" class="text-[11px] text-ink-400"></div>
      </div>
      <div id="capitalEventLog" class="mt-3"></div>
    </div>
<script>
(function() {
  const WF_BASE_URL = {{ waterfall_url_json|safe }};
  const AGENT_IDS = {{ agent_ids_json|safe }};
  const CAPITAL_STATE = {{ agent_capitals_json|safe }};
  const DEFAULT_CAPITAL = {{ sleeve_capital_krw_json|safe }};
  const SPINNER = {{ spinner_json|safe }};
  const EMPTY_HTML = {{ empty_html_json|safe }};
  const FAIL_HTML = {{ fail_html_json|safe }};
  const AGENT_THEMES = {
    gpt: { accent: "#10a37f", accentSoft: "#ecfdf5", accentMid: "#86efac", accentDeep: "#047857", accentInk: "#064e3b", glow: "rgba(16,163,127,0.22)" },
    gemini: { accent: "#4285f4", accentSoft: "#eff6ff", accentMid: "#93c5fd", accentDeep: "#1d4ed8", accentInk: "#1e3a8a", glow: "rgba(66,133,244,0.22)" },
    claude: { accent: "#d97757", accentSoft: "#fff7ed", accentMid: "#fdba74", accentDeep: "#c2410c", accentInk: "#7c2d12", glow: "rgba(217,119,87,0.22)" }
  };
  let initialized = false;

  function esc(value) {
    return String(value == null ? "" : value)
      .replace(/&/g, "&amp;")
      .replace(/</g, "&lt;")
      .replace(/>/g, "&gt;")
      .replace(/"/g, "&quot;")
      .replace(/'/g, "&#39;");
  }

  function money(value) {
    return Number(value || 0).toLocaleString();
  }

  function signedMoney(value) {
    const num = Number(value || 0);
    return (num > 0 ? "+" : "") + money(num);
  }

  function pct(value) {
    const num = Number(value || 0);
    return (num > 0 ? "+" : "") + num.toFixed(1) + "%";
  }

  function isoLabel(value) {
    const raw = String(value || "").trim();
    if (!raw) return "기록 없음";
    return raw.replace("T", " ").replace("Z", "").slice(0, 16);
  }

  function capitalValue(agentId) {
    const raw = Object.prototype.hasOwnProperty.call(CAPITAL_STATE, agentId) ? CAPITAL_STATE[agentId] : DEFAULT_CAPITAL;
    const value = Number(raw || 0);
    return value > 0 ? value : Number(DEFAULT_CAPITAL || 0);
  }

  function rgba(hex, alpha) {
    const raw = String(hex || "").replace("#", "");
    const normalized = raw.length === 3
      ? raw.split("").map(function(ch) { return ch + ch; }).join("")
      : raw.padEnd(6, "0").slice(0, 6);
    const r = parseInt(normalized.slice(0, 2), 16) || 0;
    const g = parseInt(normalized.slice(2, 4), 16) || 0;
    const b = parseInt(normalized.slice(4, 6), 16) || 0;
    return "rgba(" + r + "," + g + "," + b + "," + alpha + ")";
  }

  function theme(agentId) {
    const key = String(agentId || "").trim().toLowerCase();
    return AGENT_THEMES[key] || {
      accent: "#0ea5e9",
      accentSoft: "#f0f9ff",
      accentMid: "#7dd3fc",
      accentDeep: "#0369a1",
      accentInk: "#0c4a6e",
      glow: "rgba(14,165,233,0.22)"
    };
  }

  function tabButtons() {
    return Array.prototype.slice.call(document.querySelectorAll(".capital-agent-tab"));
  }

  function setActiveTab(agentId) {
    tabButtons().forEach(function(btn) {
      const btnAgentId = String(btn.getAttribute("data-capital-agent") || "");
      const active = btnAgentId === String(agentId || "");
      const tabTheme = theme(btnAgentId);
      if (active) {
        btn.style.background = "linear-gradient(135deg, " + tabTheme.accent + ", " + rgba(tabTheme.accent, 0.78) + ")";
        btn.style.borderColor = tabTheme.accent;
        btn.style.color = "#ffffff";
        btn.style.boxShadow = "0 10px 22px " + rgba(tabTheme.accent, 0.24);
      } else {
        btn.style.background = "";
        btn.style.borderColor = "";
        btn.style.color = "";
        btn.style.boxShadow = "";
      }
    });
  }

  function moneyClass(value, positiveCls, negativeCls) {
    const num = Number(value || 0);
    if (num > 0) return positiveCls;
    if (num < 0) return negativeCls;
    return "text-ink-500";
  }

  function summaryCard(title, value, note, valueClass) {
    return (
      '<div class="group relative overflow-hidden rounded-[18px] border border-ink-200/40 bg-gradient-to-br from-white/95 to-slate-50/70 px-4 py-3.5 shadow-[0_2px_16px_rgba(15,23,42,0.03)] backdrop-blur-sm transition-all duration-300 hover:shadow-[0_6px_24px_rgba(15,23,42,0.06)] hover:-translate-y-px">' +
      '<div class="absolute inset-0 rounded-[18px] bg-gradient-to-br from-transparent to-ink-100/10 opacity-0 transition-opacity duration-300 group-hover:opacity-100"></div>' +
      '<div class="relative">' +
      '<p class="text-[10px] font-semibold uppercase tracking-[0.2em] text-ink-400/80">' + esc(title) + '</p>' +
      '<p class="mt-1.5 text-lg font-bold font-mono tracking-tight ' + esc(valueClass || "text-ink-900") + '">' + value + '</p>' +
      (note ? '<p class="mt-1.5 text-[11px] leading-relaxed text-ink-500/70">' + note + '</p>' : "") +
      '</div></div>'
    );
  }

  function buildAgentConfig(agentId, payload) {
    const current = capitalValue(agentId);
    const summary = payload.summary || {};
    const agentTheme = theme(agentId);
    const baseline = Number(summary.baseline_equity_krw || payload.total_invested || 0);
    const seedCash = Number(summary.seed_cash_krw || payload.initial_cash || 0);
    const seedPos = Number(summary.seed_positions_cost_krw || 0);
    const checkpointMeta = isoLabel(summary.initialized_at);
    const seedSource = String(summary.seed_source || "agent_state_checkpoint").replace(/_/g, " ");
    const quickCards = [
      summaryCard("시드 구성", money(seedCash + seedPos) + '<span class="ml-1 text-xs text-ink-400/60">원</span>', "현금 " + money(seedCash) + " · 포지션 " + money(seedPos), "text-ink-900"),
      summaryCard("기준 원금", money(baseline) + '<span class="ml-1 text-xs text-ink-400/60">원</span>', "현재 장부 기준", "text-ink-900"),
      summaryCard("평가 방식", "MTM", "시가 평가 기준 · Performance 탭은 TWR 기준", "text-ink-900")
    ].join("");

    return (
      '<div class="relative overflow-hidden rounded-[22px] border border-ink-200/40 bg-gradient-to-br from-white/95 to-slate-50/60 p-5 shadow-[0_4px_24px_rgba(15,23,42,0.04)]">' +
      '<div class="pointer-events-none absolute right-[-40px] top-[-40px] h-48 w-48 rounded-full blur-[60px] opacity-60" style="background:' + agentTheme.glow + ';"></div>' +
      '<div class="relative flex flex-col gap-5 xl:flex-row xl:items-end xl:justify-between">' +
      '<div class="space-y-4">' +
      '<div class="flex flex-wrap items-center gap-2">' +
      '<span class="rounded-lg px-3 py-1 text-[11px] font-semibold text-white shadow-sm" style="background:' + agentTheme.accent + ';">' + esc(String(agentId || "").toUpperCase()) + '</span>' +
      '<span class="rounded-lg border border-ink-200/50 bg-white/80 px-2.5 py-1 text-[10px] text-ink-500/80 backdrop-blur-sm">checkpoint ' + esc(checkpointMeta) + '</span>' +
      '<span class="rounded-lg border px-2.5 py-1 text-[10px] font-medium" style="border-color:' + rgba(agentTheme.accent, 0.18) + '; color:' + agentTheme.accentDeep + '; background:' + agentTheme.accentSoft + ';">' + esc(seedSource) + '</span>' +
      '</div>' +
      '<div>' +
      '<p class="text-[10px] font-semibold uppercase tracking-[0.22em] text-ink-400/70">Target Capital</p>' +
      '<div class="mt-2 flex flex-wrap items-center gap-3">' +
      '<input id="capitalAgentInput" type="number" min="0" step="10000" value="' + esc(String(current)) + '" class="w-[200px] rounded-xl border border-ink-200/50 bg-white/80 px-4 py-2.5 text-right text-sm font-mono text-ink-900 shadow-[0_2px_8px_rgba(15,23,42,0.03)] outline-none transition-all duration-200 focus:border-transparent focus:ring-2 focus:ring-offset-1 focus:shadow-[0_4px_16px_rgba(15,23,42,0.06)]" style="--tw-ring-color:' + rgba(agentTheme.accent, 0.35) + ';" />' +
      '<span class="text-xs text-ink-400/70">원</span>' +
      '<button type="button" id="capitalSaveBtn" class="inline-flex items-center gap-2 rounded-xl px-5 py-2.5 text-xs font-semibold text-white transition-all duration-200 hover:-translate-y-0.5 hover:shadow-lg active:translate-y-0" style="background:linear-gradient(135deg,' + agentTheme.accent + ',' + agentTheme.accentDeep + '); box-shadow:0 6px 20px ' + rgba(agentTheme.accent, 0.2) + ';"><span class="capital-save-label">저장</span><span class="capital-save-spinner hidden h-3 w-3 rounded-full border-2 border-white/50 border-t-white animate-spin"></span></button>' +
      '<span id="capitalSaveStatus" role="status" aria-live="polite" class="hidden text-[11px] font-medium text-ink-500/70">Target Capital 저장 중...</span>' +
      '</div>' +
      '<p class="mt-2 text-[11px] text-ink-500/60">저장 시 이 에이전트의 target capital이 capital event로 반영됩니다.</p>' +
      '</div>' +
      '</div>' +
      '<div class="grid gap-3 sm:grid-cols-3">' + quickCards + '</div>' +
      '</div>' +
      '</div>'
    );
  }

  function buildSummaryHtml(agentId, payload) {
    const summary = payload.summary || {};
    const agentTheme = theme(agentId);
    const baseline = Number(summary.baseline_equity_krw || payload.total_invested || 0);
    const currentNav = Number(summary.current_equity_krw || payload.current_equity || 0);
    const pnl = Number(summary.pnl_krw != null ? summary.pnl_krw : (currentNav - baseline));
    const dividend = Number(summary.dividend_income_krw || 0);
    const pnlClass = moneyClass(pnl, "text-emerald-600", "text-rose-600");
    const cards = [
      summaryCard("기준 원금", money(baseline) + '<span class="ml-1 text-xs text-ink-400/60">원</span>', "시드 + 자본 이벤트 + 이체/보정", "text-ink-900"),
      summaryCard("현재 NAV", money(currentNav) + '<span class="ml-1 text-xs text-ink-400/60">원</span>', "현금 " + money(summary.current_cash_krw || 0) + " · 포지션 " + money(summary.current_positions_value_krw || 0), "text-ink-900"),
      summaryCard("평가손익", signedMoney(pnl) + '<span class="ml-1 text-xs text-ink-400/60">원</span>', "기준 원금 대비" + (dividend ? " · 배당 " + signedMoney(dividend) : ""), pnlClass),
      summaryCard("자본 이벤트", signedMoney(summary.capital_flow_krw || 0) + '<span class="ml-1 text-xs text-ink-400/60">원</span>', "이벤트 " + String(summary.capital_event_count || 0) + "건 · 이체/보정 " + String(summary.transfer_and_adjustment_count || 0) + "건", moneyClass(summary.capital_flow_krw || 0, "text-emerald-600", "text-rose-600"))
    ];
    return (
      '<div class="space-y-4">' +
      '<div class="flex items-center gap-2 rounded-2xl border bg-gradient-to-r from-white/90 to-white/60 px-4 py-2.5 text-[10px] backdrop-blur-sm" style="border-color:' + rgba(agentTheme.accent, 0.12) + '; box-shadow:0 2px 12px ' + rgba(agentTheme.accent, 0.04) + ';">' +
      '<span class="inline-flex shrink-0 items-center rounded-md px-2 py-0.5 font-semibold" style="background:' + agentTheme.accentSoft + '; color:' + agentTheme.accentDeep + ';">장부 기준</span>' +
      '<span class="text-ink-400">원금 대비 평가손익</span>' +
      '<span class="text-ink-300">&middot;</span>' +
      '<span class="text-ink-400">Performance 탭도 총투입원금 기준</span>' +
      '</div>' +
      '<div class="grid gap-3 md:grid-cols-2 xl:grid-cols-4">' + cards.join("") + '</div>' +
      '</div>'
    );
  }

  function buildNode(x, y, w, h, title, value, meta, palette, accentWidth) {
    const accent = Math.max(Number(accentWidth || 64), 48);
    return (
      '<g transform="translate(' + x + ' ' + y + ')" class="capital-node">' +
      '<rect width="' + w + '" height="' + h + '" rx="16" fill="' + palette.fill + '" stroke="' + palette.stroke + '" stroke-width="0.8" opacity="0.97"></rect>' +
      '<rect x="16" y="14" width="' + accent + '" height="2.5" rx="1.25" fill="' + palette.accent + '" opacity="0.7"></rect>' +
      '<text x="18" y="30" font-size="10" font-weight="600" letter-spacing="2" fill="' + palette.kicker + '" opacity="0.7">' + esc(title).toUpperCase() + '</text>' +
      '<text x="18" y="58" font-size="21" font-weight="700" fill="' + palette.value + '">' + esc(value) + '</text>' +
      '<text x="18" y="' + (meta ? 78 : 74) + '" font-size="10.5" fill="' + palette.meta + '" opacity="0.6">' + esc(meta || "") + '</text>' +
      '</g>'
    );
  }

  function buildStagePill(x, label, fill, stroke, text) {
    return (
      '<g transform="translate(' + x + ' 30)">' +
      '<rect width="118" height="26" rx="13" fill="' + fill + '" stroke="' + stroke + '" stroke-width="0.7" opacity="0.85"></rect>' +
      '<text x="59" y="17" text-anchor="middle" font-size="9.5" font-weight="600" letter-spacing="1.8" fill="' + text + '" opacity="0.8">' + esc(label).toUpperCase() + '</text>' +
      '</g>'
    );
  }

  function palette(fill, stroke, value, kicker, meta, accent) {
    return { fill: fill, stroke: stroke, value: value, kicker: kicker, meta: meta, accent: accent };
  }

  function buildLineageSvg(agentId, payload) {
    const summary = payload.summary || {};
    const agentTheme = theme(agentId);
    const checkpointMeta = isoLabel(summary.initialized_at);
    const seedCash = Number(summary.seed_cash_krw || payload.initial_cash || 0);
    const seedPos = Number(summary.seed_positions_cost_krw || 0);
    const capFlow = Number(summary.capital_flow_krw || 0);
    const moveFlow = Number(summary.transfer_and_adjustment_krw || 0);
    const baseline = Number(summary.baseline_equity_krw || payload.total_invested || 0);
    const currentNav = Number(summary.current_equity_krw || payload.current_equity || 0);
    const pnl = Number(summary.pnl_krw != null ? summary.pnl_krw : (currentNav - baseline));
    const dividend = Number(summary.dividend_income_krw || 0);
    const dividendLabel = dividend ? "배당 " + signedMoney(dividend) : "";
    const seedTotal = seedCash + seedPos;
    const agentLabel = String(agentId || "").trim().toUpperCase();

    const checkpointPalette = palette("#0f172a", "#1e293b", "#f8fafc", "#cbd5e1", "#94a3b8", agentTheme.accentMid);
    const seedPalette = palette("#ffffff", "#dbe3ee", "#0f172a", "#64748b", "#94a3b8", agentTheme.accent);
    const capitalPalette = capFlow >= 0
      ? palette("#ecfdf5", "#86efac", "#047857", "#10b981", "#059669", "#34d399")
      : palette("#fff7ed", "#fdba74", "#c2410c", "#f97316", "#c2410c", "#fb923c");
    const movePalette = moveFlow >= 0
      ? palette("#eff6ff", "#93c5fd", "#1d4ed8", "#3b82f6", "#2563eb", "#60a5fa")
      : palette("#fff7ed", "#fdba74", "#b45309", "#f59e0b", "#b45309", "#f59e0b");
    const baselinePalette = palette("#ffffff", "#cbd5e1", "#0f172a", "#475569", "#64748b", agentTheme.accent);
    const navPalette = palette(rgba(agentTheme.accent, 0.1), rgba(agentTheme.accent, 0.36), agentTheme.accentInk, agentTheme.accent, agentTheme.accentDeep, agentTheme.accent);
    const pnlPalette = pnl >= 0
      ? palette("#ecfdf5", "#86efac", "#047857", "#10b981", "#059669", "#34d399")
      : palette("#fff1f2", "#fda4af", "#be123c", "#f43f5e", "#e11d48", "#fb7185");

    const stagePills = [
      buildStagePill(30, "Checkpoint", "#ffffff", "#dbe3ee", "#475569"),
      buildStagePill(246, "Seed", rgba(agentTheme.accent, 0.08), rgba(agentTheme.accent, 0.18), agentTheme.accentDeep),
      buildStagePill(454, "Events", "#ffffff", "#dbe3ee", "#475569"),
      buildStagePill(672, "Baseline", "#ffffff", "#dbe3ee", "#475569"),
      buildStagePill(916, "Current NAV", rgba(agentTheme.accent, 0.08), rgba(agentTheme.accent, 0.18), agentTheme.accentDeep)
    ].join("");

    const checkpoint = buildNode(34, 148, 184, 104, "Checkpoint", "Seed State", checkpointMeta, checkpointPalette, 74);
    const seedNode = buildNode(264, 88, 254, 96, "Seed Capital", money(seedTotal) + "원", "현금 " + money(seedCash) + " · 포지션 " + money(seedPos), seedPalette, 84);
    const capitalNode = buildNode(264, 206, 254, 90, "Capital Events", signedMoney(capFlow) + "원", "이벤트 " + String(summary.capital_event_count || 0) + "건", capitalPalette, 84);
    const moveNode = buildNode(264, 316, 254, 90, "Transfer / Adj", signedMoney(moveFlow) + "원", "이체·보정 " + String(summary.transfer_and_adjustment_count || 0) + "건", movePalette, 84);
    const baselineNode = buildNode(624, 162, 234, 104, "Baseline", money(baseline) + "원", "기준 원금", baselinePalette, 82);
    const navNode = buildNode(920, 144, 258, 112, "Current NAV", money(currentNav) + "원", "현금 " + money(summary.current_cash_krw || 0) + " · 포지션 " + money(summary.current_positions_value_krw || 0), navPalette, 94);
    const pnlNode = buildNode(920, 282, 258, 88, "평가손익", signedMoney(pnl) + "원", "기준 원금 대비" + (dividendLabel ? " · " + dividendLabel : ""), pnlPalette, 92);

    return (
      '<div class="space-y-4">' +
      '<div class="flex flex-col gap-3 lg:flex-row lg:items-center lg:justify-between">' +
      '<div>' +
      '<p class="text-[10px] font-semibold uppercase tracking-[0.22em] text-ink-400/70">Ledger Lineage</p>' +
      '<h5 class="mt-1 text-sm font-bold text-ink-900">' + esc(agentLabel) + ' 장부 계보</h5>' +
      '<p class="mt-1 text-[11px] text-ink-500/60">Checkpoint에서 현재 NAV까지 기준 원금 형성 경로를 단계별로 보여줍니다.</p>' +
      '</div>' +
      '<div class="flex flex-wrap items-center gap-1.5 text-[10px]">' +
      '<span class="rounded-lg border px-2.5 py-1 font-medium" style="border-color:' + rgba(agentTheme.accent, 0.15) + '; background:' + agentTheme.accentSoft + '; color:' + agentTheme.accentDeep + ';">원금 대비 평가손익</span>' +
      '<span class="rounded-lg border border-ink-200/40 bg-white/80 px-2.5 py-1 text-ink-500/70">checkpoint ' + esc(checkpointMeta) + '</span>' +
      '</div>' +
      '</div>' +
      '<div class="overflow-x-auto pb-2">' +
      '<svg viewBox="0 0 1220 430" class="min-w-[1020px] w-full" role="img" aria-label="capital lineage graph">' +
      '<defs>' +
      '<marker id="capitalLineageArrow" markerWidth="10" markerHeight="10" refX="9" refY="5" orient="auto" markerUnits="strokeWidth">' +
      '<path d="M1,1 L9,5 L1,9" fill="none" stroke="' + rgba(agentTheme.accent, 0.5) + '" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"></path>' +
      '</marker>' +
      '<marker id="capitalLineageArrowSub" markerWidth="8" markerHeight="8" refX="7" refY="4" orient="auto" markerUnits="strokeWidth">' +
      '<path d="M1,1 L7,4 L1,7" fill="none" stroke="#94a3b8" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round"></path>' +
      '</marker>' +
      '<linearGradient id="capitalFlowGradient" x1="0%" y1="0%" x2="100%" y2="0%">' +
      '<stop offset="0%" stop-color="' + rgba(agentTheme.accent, 0.12) + '"></stop>' +
      '<stop offset="50%" stop-color="' + rgba(agentTheme.accent, 0.4) + '"></stop>' +
      '<stop offset="100%" stop-color="' + rgba(agentTheme.accent, 0.65) + '"></stop>' +
      '</linearGradient>' +
      '<filter id="capitalSoftShadow" x="-10%" y="-10%" width="120%" height="120%">' +
      '<feDropShadow dx="0" dy="6" stdDeviation="12" flood-color="' + rgba(agentTheme.accent, 0.08) + '"></feDropShadow>' +
      '</filter>' +
      '</defs>' +
      '<style>' +
      '@keyframes capitalFlowDash{to{stroke-dashoffset:-24;}}' +
      '.capital-flow{stroke-dasharray:10 6;animation:capitalFlowDash 2s linear infinite;}' +
      '.capital-flow-sub{stroke-dasharray:6 5;animation:capitalFlowDash 2.5s linear infinite;}' +
      '.capital-node{transition:opacity 0.3s ease;}' +
      '</style>' +
      '<g opacity="1">' +
      '<circle cx="1080" cy="86" r="100" fill="' + rgba(agentTheme.accent, 0.06) + '"></circle>' +
      '<circle cx="156" cy="354" r="80" fill="' + rgba(agentTheme.accent, 0.04) + '"></circle>' +
      '<circle cx="600" cy="200" r="140" fill="' + rgba(agentTheme.accent, 0.02) + '"></circle>' +
      '<path d="M216 202 C244 150 252 136 264 136" stroke="url(#capitalFlowGradient)" stroke-width="2.5" fill="none" stroke-linecap="round" class="capital-flow" marker-end="url(#capitalLineageArrow)"></path>' +
      '<path d="M216 212 C244 212 252 244 264 250" stroke="#cbd5e1" stroke-width="1.8" fill="none" stroke-linecap="round" class="capital-flow-sub" marker-end="url(#capitalLineageArrowSub)"></path>' +
      '<path d="M216 224 C244 274 252 348 264 360" stroke="#e2e8f0" stroke-width="1.8" fill="none" stroke-linecap="round" class="capital-flow-sub" marker-end="url(#capitalLineageArrowSub)"></path>' +
      '<path d="M518 136 C568 140 580 196 624 210" stroke="url(#capitalFlowGradient)" stroke-width="2.5" fill="none" stroke-linecap="round" class="capital-flow" marker-end="url(#capitalLineageArrow)"></path>' +
      '<path d="M518 252 C568 252 582 220 624 216" stroke="#cbd5e1" stroke-width="1.8" fill="none" stroke-linecap="round" class="capital-flow-sub" marker-end="url(#capitalLineageArrowSub)"></path>' +
      '<path d="M518 360 C568 358 586 236 624 224" stroke="#e2e8f0" stroke-width="1.8" fill="none" stroke-linecap="round" class="capital-flow-sub" marker-end="url(#capitalLineageArrowSub)"></path>' +
      '<path d="M858 214 C890 214 902 202 920 202" stroke="url(#capitalFlowGradient)" stroke-width="2.5" fill="none" stroke-linecap="round" class="capital-flow" marker-end="url(#capitalLineageArrow)"></path>' +
      '<path d="M1048 282 C1048 270 1048 264 1048 258" stroke="' + (pnl >= 0 ? "rgba(16,185,129,0.5)" : "rgba(244,63,94,0.5)") + '" stroke-width="1.8" fill="none" stroke-linecap="round" class="capital-flow-sub" marker-end="url(#capitalLineageArrowSub)"></path>' +
      '<path d="M150 202 L920 202" stroke="' + rgba(agentTheme.accent, 0.05) + '" stroke-width="1" stroke-dasharray="4 8"></path>' +
      '</g>' +
      stagePills +
      '<g filter="url(#capitalSoftShadow)">' + checkpoint + seedNode + capitalNode + moveNode + baselineNode + navNode + pnlNode + '</g>' +
      '</svg>' +
      '</div>' +
      '</div>'
    );
  }

  function buildEventLog(payload) {
    const events = payload.events || [];
    const summary = payload.summary || {};
    const seedCash = Number(summary.seed_cash_krw != null ? summary.seed_cash_krw : payload.initial_cash || 0);
    const seedPos = Number(summary.seed_positions_cost_krw || 0);
    let running = seedCash;
    const rows = [
      '<tr class="border-b border-ink-100/40 bg-slate-50/30">' +
      '<td class="px-3.5 py-2.5 text-[11px] text-ink-400">-</td>' +
      '<td class="px-3.5 py-2.5 text-[11px] font-medium text-ink-700">시드 현금</td>' +
      '<td class="px-3.5 py-2.5 text-right text-[11px] font-mono text-ink-600/80">' + money(seedCash) + '</td>' +
      '<td class="px-3.5 py-2.5 text-right text-[11px] font-mono font-semibold text-ink-900">' + money(running) + '</td>' +
      '</tr>'
    ];
    if (seedPos !== 0) {
      running += seedPos;
      rows.push(
        '<tr class="border-b border-ink-100/40 bg-slate-50/30">' +
        '<td class="px-3.5 py-2.5 text-[11px] text-ink-400">-</td>' +
        '<td class="px-3.5 py-2.5 text-[11px] font-medium text-ink-700">시드 포지션 원가</td>' +
        '<td class="px-3.5 py-2.5 text-right text-[11px] font-mono text-ink-600/80">' + money(seedPos) + '</td>' +
        '<td class="px-3.5 py-2.5 text-right text-[11px] font-mono font-semibold text-ink-900">' + money(running) + '</td>' +
        '</tr>'
      );
    }
    events.forEach(function(event, idx) {
      const amount = Number(event.amount || 0);
      const type = String(event.type || "");
      let tone = "text-ink-700";
      let badge = "border-ink-200/40 bg-ink-50 text-ink-500";
      if (type === "deposit") {
        tone = "text-emerald-700";
        badge = "border-emerald-200/50 bg-emerald-50/80 text-emerald-700";
      } else if (type === "withdrawal") {
        tone = "text-amber-700";
        badge = "border-amber-200/50 bg-amber-50/80 text-amber-700";
      } else if (type === "transfer") {
        tone = "text-sky-700";
        badge = "border-sky-200/50 bg-sky-50/80 text-sky-700";
      } else if (type === "manual_adjustment") {
        tone = "text-violet-700";
        badge = "border-violet-200/50 bg-violet-50/80 text-violet-700";
      }
      running += amount;
      rows.push(
        '<tr class="border-b border-ink-100/30 transition-colors duration-150 hover:bg-slate-50/50">' +
        '<td class="px-3.5 py-2.5 text-[11px] text-ink-400/80 tabular-nums">' + esc(event.date || "") + '</td>' +
        '<td class="px-3.5 py-2.5 text-[11px] font-medium ' + tone + '"><span class="mr-2 inline-flex rounded-md border px-2 py-0.5 text-[9px] font-semibold ' + badge + '">' + esc(type || "event") + '</span>' + esc(event.label || "") + '</td>' +
        '<td class="px-3.5 py-2.5 text-right text-[11px] font-mono tabular-nums ' + moneyClass(amount, "text-emerald-600", "text-rose-600") + '">' + signedMoney(amount) + '</td>' +
        '<td class="px-3.5 py-2.5 text-right text-[11px] font-mono font-semibold tabular-nums text-ink-900">' + money(running) + '</td>' +
        '</tr>'
      );
    });
    return (
      '<div class="max-h-[360px] overflow-y-auto rounded-2xl border border-ink-200/30 shadow-[0_2px_12px_rgba(15,23,42,0.02)]">' +
      '<table class="min-w-full text-left">' +
      '<thead class="sticky top-0 z-10 bg-gradient-to-b from-white via-white to-white/95 backdrop-blur-md">' +
      '<tr class="border-b border-ink-200/40 text-[9px] font-semibold uppercase tracking-[0.2em] text-ink-400/70">' +
      '<th class="px-3.5 py-2.5">날짜</th>' +
      '<th class="px-3.5 py-2.5">이벤트</th>' +
      '<th class="px-3.5 py-2.5 text-right">금액</th>' +
      '<th class="px-3.5 py-2.5 text-right">누적 기준 원금</th>' +
      '</tr>' +
      '</thead>' +
      '<tbody>' + rows.join("") + '</tbody>' +
      '</table>' +
      '</div>'
    );
  }

  function setCapitalSaving(isSaving) {
    const input = document.getElementById("capitalAgentInput");
    const btn = document.getElementById("capitalSaveBtn");
    const label = btn ? btn.querySelector(".capital-save-label") : null;
    const spinner = btn ? btn.querySelector(".capital-save-spinner") : null;
    const status = document.getElementById("capitalSaveStatus");
    if (input) input.disabled = !!isSaving;
    if (btn) {
      btn.disabled = !!isSaving;
      btn.classList.toggle("opacity-70", !!isSaving);
      btn.classList.toggle("cursor-not-allowed", !!isSaving);
      btn.classList.toggle("hover:-translate-y-0.5", !isSaving);
    }
    if (label) label.textContent = isSaving ? "저장 중..." : "저장";
    if (spinner) spinner.classList.toggle("hidden", !isSaving);
    if (status) {
      status.textContent = isSaving ? "Target Capital 저장 중..." : "";
      status.classList.toggle("hidden", !isSaving);
    }
  }

  function submitCapitalState() {
    const payload = {};
    let maxCap = 0;
    AGENT_IDS.forEach(function(agentId) {
      const value = capitalValue(agentId);
      if (value > 0) {
        payload[agentId] = value;
        if (value > maxCap) maxCap = value;
      }
    });
    const defaultHidden = document.getElementById("capitalDefaultHidden");
    const agentsHidden = document.getElementById("capitalAgentsHidden");
    const form = document.getElementById("capitalDefaultForm");
    if (defaultHidden) defaultHidden.value = String(maxCap || 0);
    if (agentsHidden) agentsHidden.value = JSON.stringify(payload);
    if (!form) return;
    setCapitalSaving(true);
    try {
      if (typeof form.requestSubmit === "function") {
        form.requestSubmit();
        return;
      }
    } catch (err) {
      console.warn("[capital] requestSubmit failed; falling back to submit event", err);
    }
    const fallbackSubmitter = document.createElement("button");
    fallbackSubmitter.type = "submit";
    fallbackSubmitter.hidden = true;
    form.appendChild(fallbackSubmitter);
    fallbackSubmitter.click();
    fallbackSubmitter.remove();
  }

  var holdingsChart = null;

  function renderHoldings(agentId, payload) {
    var wrap = document.getElementById("capitalHoldingsChart");
    if (!wrap) return;
    var h = payload.holdings;
    if (!h || !h.labels || h.labels.length < 2) {
      wrap.classList.add("hidden");
      wrap.innerHTML = "";
      return;
    }
    wrap.classList.remove("hidden");
    var agentTheme = theme(agentId);
    var colors = [rgba(agentTheme.accent, 0.18), "#f43f5e", "#3b82f6", "#8b5cf6", "#10b981", "#f59e0b", "#ec4899", "#14b8a6", "#6366f1", "#f97316"];
    var total = h.data.reduce(function(a, b) { return a + b; }, 0);

    var posCount = h.labels.length - 1;
    var items = "";
    for (var i = 1; i < h.labels.length; i++) {
      var color = colors[i % colors.length];
      var pctVal = total > 0 ? (h.data[i] / total * 100).toFixed(1) : "0.0";
      items +=
        '<div class="flex items-center gap-1.5 rounded-lg border border-ink-100/60 bg-white/70 px-2 py-1">' +
        '<span class="w-1.5 h-1.5 rounded-full shrink-0" style="background:' + color + ';"></span>' +
        '<span class="text-[11px] font-semibold text-ink-800">' + esc(h.labels[i]) + '</span>' +
        '<span class="text-[10px] text-ink-400 font-mono">' + pctVal + '%</span>' +
        '</div>';
    }

    var cid = "capitalDoughnut_" + Date.now();
    wrap.innerHTML =
      '<div class="mt-5 grid grid-cols-[auto_1fr] gap-4 items-center rounded-[18px] border border-ink-200/30 ' +
      'bg-gradient-to-r from-white/95 to-slate-50/60 px-4 py-3 shadow-[0_2px_12px_rgba(15,23,42,0.03)]">' +
      '<div class="relative w-[100px] h-[100px] shrink-0"><canvas id="' + cid + '"></canvas>' +
      '<div class="absolute inset-0 flex items-center justify-center pointer-events-none">' +
      '<span class="text-[10px] font-bold text-ink-500">' + posCount + '종목</span></div></div>' +
      '<div class="min-w-0">' +
      '<div class="flex items-center gap-2 mb-2">' +
      '<p class="text-[10px] font-semibold uppercase tracking-[0.2em] text-ink-400/70">Holdings</p>' +
      '<span class="text-[10px] text-ink-300 font-mono">Cash ' + money(h.data[0]) + '원</span>' +
      '</div>' +
      '<div class="flex flex-wrap gap-1.5">' + items + '</div>' +
      '</div></div>';

    if (holdingsChart) { holdingsChart.destroy(); holdingsChart = null; }
    var canvas = document.getElementById(cid);
    if (canvas && typeof Chart !== "undefined") {
      holdingsChart = new Chart(canvas, {
        type: "doughnut",
        data: { labels: h.labels, datasets: [{ data: h.data, backgroundColor: colors.slice(0, h.labels.length), borderWidth: 0, hoverOffset: 3 }] },
        options: {
          responsive: true, maintainAspectRatio: true, cutout: "70%",
          animation: { duration: 500 },
          plugins: {
            legend: { display: false },
            tooltip: { backgroundColor: "rgba(15,23,42,0.92)", titleColor: "#f8fafc", bodyColor: "#e2e8f0", cornerRadius: 8, padding: 8, bodyFont: { size: 11 },
              callbacks: { label: function(c) { return " " + c.label + ": " + (c.raw || 0).toLocaleString() + "원 (" + (total > 0 ? (c.raw / total * 100).toFixed(1) : "0") + "%)"; } } }
          }
        }
      });
    }
  }

  function renderPayload(agentId, payload) {
    const configEl = document.getElementById("capitalAgentConfig");
    const summaryEl = document.getElementById("capitalLineageSummary");
    const graphEl = document.getElementById("capitalLineageGraph");
    const logEl = document.getElementById("capitalEventLog");
    const metaEl = document.getElementById("capitalLedgerMeta");
    if (!configEl || !summaryEl || !graphEl || !logEl || !metaEl) return;

    const summary = payload.summary || {};
    configEl.innerHTML = buildAgentConfig(agentId, payload);
    renderHoldings(agentId, payload);
    summaryEl.innerHTML = buildSummaryHtml(agentId, payload);
    graphEl.innerHTML = buildLineageSvg(agentId, payload);
    logEl.innerHTML = buildEventLog(payload);
    metaEl.innerHTML =
      '<span class="rounded-lg border border-ink-200/40 bg-white/80 px-2 py-0.5 text-[10px]">' + esc(String(agentId || "").toUpperCase()) + '</span>' +
      '<span class="ml-1.5 rounded-lg border border-ink-200/40 bg-white/80 px-2 py-0.5 text-[10px]">' + esc(isoLabel(summary.initialized_at)) + '</span>';

    const input = document.getElementById("capitalAgentInput");
    if (input) {
      input.addEventListener("input", function() {
        CAPITAL_STATE[agentId] = parseFloat(input.value || "0") || 0;
      });
    }
    const saveBtn = document.getElementById("capitalSaveBtn");
    if (saveBtn) saveBtn.addEventListener("click", submitCapitalState);
  }

  function showLoading() {
    const configEl = document.getElementById("capitalAgentConfig");
    const summaryEl = document.getElementById("capitalLineageSummary");
    const graphEl = document.getElementById("capitalLineageGraph");
    const logEl = document.getElementById("capitalEventLog");
    const metaEl = document.getElementById("capitalLedgerMeta");
    const holdingsWrap = document.getElementById("capitalHoldingsChart");
    if (configEl) configEl.innerHTML = SPINNER;
    if (summaryEl) summaryEl.innerHTML = SPINNER;
    if (graphEl) graphEl.innerHTML = SPINNER;
    if (logEl) logEl.innerHTML = "";
    if (metaEl) metaEl.textContent = "";
    if (holdingsWrap) holdingsWrap.classList.add("hidden");
    if (holdingsChart) { holdingsChart.destroy(); holdingsChart = null; }
  }

  function loadAgent(agentId) {
    if (!agentId) {
      const configEl = document.getElementById("capitalAgentConfig");
      const graphEl = document.getElementById("capitalLineageGraph");
      const summaryEl = document.getElementById("capitalLineageSummary");
      const logEl = document.getElementById("capitalEventLog");
      if (configEl) configEl.innerHTML = EMPTY_HTML;
      if (graphEl) graphEl.innerHTML = EMPTY_HTML;
      if (summaryEl) summaryEl.innerHTML = EMPTY_HTML;
      if (logEl) logEl.innerHTML = "";
      return;
    }
    setActiveTab(agentId);
    showLoading();
    fetch(WF_BASE_URL + "&agent_id=" + encodeURIComponent(agentId))
      .then(function(resp) {
        if (!resp.ok) throw new Error("HTTP " + resp.status);
        return resp.json();
      })
      .then(function(payload) { renderPayload(agentId, payload || {}); })
      .catch(function(err) {
        console.error("[capital] loadAgent failed:", agentId, err);
        const detail = err && err.message ? " (" + esc(err.message) + ")" : "";
        const failMsg = '<p class="py-12 text-center text-sm text-ink-400">로드 실패' + detail + '</p>';
        const configEl = document.getElementById("capitalAgentConfig");
        const graphEl = document.getElementById("capitalLineageGraph");
        const summaryEl = document.getElementById("capitalLineageSummary");
        const logEl = document.getElementById("capitalEventLog");
        if (configEl) configEl.innerHTML = failMsg;
        if (graphEl) graphEl.innerHTML = failMsg;
        if (summaryEl) summaryEl.innerHTML = failMsg;
        if (logEl) logEl.innerHTML = "";
      });
  }

  function initTabs() {
    tabButtons().forEach(function(btn) {
      btn.addEventListener("click", function() {
        loadAgent(String(btn.getAttribute("data-capital-agent") || ""));
      });
    });
  }

  function initCapitalPanel() {
    initTabs();
    if (AGENT_IDS.length) loadAgent(AGENT_IDS[0]);
    else {
      const configEl = document.getElementById("capitalAgentConfig");
      const graphEl = document.getElementById("capitalLineageGraph");
      const summaryEl = document.getElementById("capitalLineageSummary");
      if (configEl) configEl.innerHTML = EMPTY_HTML;
      if (graphEl) graphEl.innerHTML = EMPTY_HTML;
      if (summaryEl) summaryEl.innerHTML = EMPTY_HTML;
    }
  }

  document.addEventListener("settings-tab-activated", function(ev) {
    if (!ev || !ev.detail || ev.detail.tab !== "capital" || initialized) return;
    initialized = true;
    initCapitalPanel();
  });
})();
</script>
  </div>
</div>
