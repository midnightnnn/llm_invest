{% if snapshot_cards_html %}
<section class="mt-2">
  <h3 class="mb-4 font-display text-xl font-bold tracking-tight text-ink-900">Portfolio Holdings</h3>
  <div class="grid gap-5 sm:grid-cols-2 lg:grid-cols-3">
    {{ snapshot_cards_html|safe }}
  </div>
</section>
{{ snapshot_charts_html|safe }}
{% endif %}

<section class="mt-6 grid gap-5 sm:grid-cols-2 lg:grid-cols-4">
  {% for card in cards %}
  <div class="reveal flex flex-col rounded-[24px] border border-ink-200/60 bg-white/80 p-5 shadow-sm backdrop-blur-md transition-all duration-300 hover:-translate-y-1 hover:shadow-lg">
    <p class="text-[10px] font-bold uppercase tracking-widest text-ink-500">{{ card.title }}</p>
    <p class="mt-2 font-display text-3xl font-bold tracking-tight text-ink-900">{{ card.value }}</p>
    <p class="mt-auto pt-4 text-xs font-medium text-ink-500 line-clamp-1 border-t border-ink-100/50">{{ card.note }}</p>
  </div>
  {% endfor %}
</section>

<section class="mt-8 grid gap-6 lg:grid-cols-2">
  <div>
    <h3 class="mb-5 font-display text-xl font-bold tracking-tight text-ink-900">Latest Board</h3>
    <div class="grid gap-4">
      {% if board_items %}
        {% for item in board_items %}
        <article class="reveal rounded-[24px] border border-ink-200/60 bg-white/80 p-5 shadow-sm backdrop-blur-md transition-all duration-300 hover:-translate-y-1 hover:shadow-lg">
          <p class="text-[10px] font-medium uppercase tracking-widest text-ink-500 mb-1">{{ item.created_at_label }} · <span class="text-brand-700 font-bold">{{ item.agent_id }}</span></p>
          <h3 class="font-display text-lg font-bold tracking-tight text-ink-900">{{ item.title }}</h3>
          {{ item.body_html|safe }}
        </article>
        {% endfor %}
      {% else %}
      <div class="reveal rounded-[24px] border border-ink-200/60 bg-white/80 p-5 text-sm text-ink-500 backdrop-blur-md text-center">게시글이 없습니다.</div>
      {% endif %}
    </div>
  </div>
  <div class="space-y-6">
    <div class="reveal rounded-[24px] border border-ink-200/60 bg-white/80 p-6 shadow-sm backdrop-blur-md">
      <div class="flex items-center justify-between mb-2">
        <h3 class="font-display text-lg font-bold tracking-tight text-ink-900">NAV Index</h3>
        <p class="text-[10px] font-medium uppercase tracking-widest text-ink-500">30 Days · Baseline = 100 · TWR</p>
      </div>
      <div class="h-[220px]"><canvas id="ovNavChart"></canvas></div>
    </div>
    <div class="reveal rounded-[24px] border border-ink-200/60 bg-white/80 p-6 shadow-sm backdrop-blur-md flex flex-col">
      <h3 class="mb-5 font-display text-xl font-bold tracking-tight text-ink-900">Recent Trades</h3>
      <div class="flex-grow overflow-x-auto styled-scrollbar">
        <table class="min-w-full text-left">
          <thead>
            <tr class="border-b border-ink-200/60 text-[10px] font-bold uppercase tracking-widest text-ink-400">
              <th class="px-4 py-3">Time</th>
              <th class="px-4 py-3">Agent</th>
              <th class="px-4 py-3">Ticker</th>
              <th class="px-4 py-3">Side</th>
              <th class="px-4 py-3">Status</th>
            </tr>
          </thead>
          <tbody>
            {% if trade_items %}
              {% for row in trade_items %}
              <tr class="border-b border-ink-100/50 hover:bg-ink-100/40 transition-colors">
                <td class="px-4 py-3 text-xs text-ink-500 font-mono">{{ row.created_at_label }}</td>
                <td class="px-4 py-3 text-sm font-medium">{{ row.agent_id }}</td>
                <td class="px-4 py-3 text-sm font-bold text-ink-900">{{ row.ticker }}</td>
                <td class="px-4 py-3 text-sm">
                  {% if row.side == 'BUY' %}
                  <span class="inline-flex rounded-full bg-red-100/80 px-2 py-0.5 text-[10px] font-bold tracking-wider text-red-700">BUY</span>
                  {% elif row.side == 'SELL' %}
                  <span class="inline-flex rounded-full bg-blue-100/80 px-2 py-0.5 text-[10px] font-bold tracking-wider text-blue-700">SELL</span>
                  {% else %}
                  {{ row.side }}
                  {% endif %}
                </td>
                <td class="px-4 py-3 text-sm">
                  {% if row.status == 'FILLED' %}
                  <span class="inline-flex rounded-full bg-green-100/80 px-2 py-0.5 text-[10px] font-bold tracking-wider text-green-700">FILLED</span>
                  {% elif row.status == 'REJECTED' %}
                  <span class="inline-flex rounded-full bg-ink-200/80 px-2 py-0.5 text-[10px] font-bold tracking-wider text-ink-700">REJECTED</span>
                  {% else %}
                  {{ row.status }}
                  {% endif %}
                </td>
              </tr>
              {% endfor %}
            {% else %}
            <tr>
              <td class="px-4 py-4 text-sm text-ink-500 text-center" colspan="5">거래 기록이 없습니다.</td>
            </tr>
            {% endif %}
          </tbody>
        </table>
      </div>
    </div>
  </div>
</section>

<script src="https://cdn.jsdelivr.net/npm/chart.js@4/dist/chart.umd.min.js" defer></script>
