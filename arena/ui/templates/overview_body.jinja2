  var logoImgs={};Object.keys(LOGOS).forEach(function(k){var img=new Image(20,20);img.src=LOGOS[k];logoImgs[k]=img;});
  function go(){
    if(typeof Chart==="undefined"){setTimeout(go,100);return;}
    fetch(url).then(function(r){return r.json()}).then(function(p){if(p&&p.error){throw new Error(p.error);}
      p.nav.forEach(function(ds){
        var key=ds.label.toLowerCase();
        if(logoImgs[key]){ds.pointStyle=logoImgs[key];var li=ds.data.length-1;while(li>=0&&ds.data[li]==null){li--;}ds.pointRadius=function(ctx){return ctx.dataIndex===li?12:0;};}else{ds.pointRadius=0;}
        ds.borderWidth=2.5;ds.tension=0.25;ds.fill=true;
        ds.backgroundColor=function(ctx){var c=ctx.chart.ctx;var a=ctx.chart.chartArea;if(!a){return "transparent";}var g=c.createLinearGradient(0,a.top,0,a.bottom);g.addColorStop(0,ds.borderColor+"25");g.addColorStop(1,ds.borderColor+"02");return g;};
      });
      new Chart(document.getElementById("ovNavChart"),{type:"line",data:{labels:p.labels,datasets:p.nav},options:{responsive:true,maintainAspectRatio:false,spanGaps:true,animation:{duration:800,easing:"easeOutQuart"},interaction:{mode:"index",intersect:false},plugins:{legend:{labels:{color:"#334155",usePointStyle:true,pointStyleWidth:14,padding:16,font:{size:12,weight:"600"}}},tooltip:{backgroundColor:"rgba(15,23,42,0.92)",titleColor:"#f8fafc",bodyColor:"#e2e8f0",cornerRadius:10,padding:12,usePointStyle:true}},scales:{x:{ticks:{color:"#94a3b8",font:{size:10},maxRotation:0,autoSkip:true,maxTicksLimit:10},grid:{color:"rgba(148,163,184,0.12)"},border:{display:false}},y:{ticks:{color:"#94a3b8",font:{size:11}},grid:{color:"rgba(148,163,184,0.12)"},border:{display:false}}}}});
