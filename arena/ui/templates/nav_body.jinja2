        var key=ds.label.toLowerCase();
        if(logoImgs[key]){ds.pointStyle=logoImgs[key];var lastIdx=ds.data.length-1;while(lastIdx>=0&&ds.data[lastIdx]==null){lastIdx--;}ds.pointRadius=function(ctx){return ctx.dataIndex===lastIdx?12:0;};}else{ds.pointRadius=0;}
