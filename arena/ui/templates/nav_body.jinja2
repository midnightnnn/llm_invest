  var tfLogoImgs={};Object.keys(TF_LOGOS).forEach(function(k){var img=new Image(20,20);img.src=TF_LOGOS[k];tfLogoImgs[k]=img;});
  function waitChart(cb){if(typeof Chart!=="undefined")cb();else setTimeout(function(){waitChart(cb);},100);}
  waitChart(function(){
    fetch(tfUrl).then(function(r){return r.json();}).then(function(payload){if(payload&&payload.error){throw new Error(payload.error);}
      var tools=Array.isArray(payload.tools)?payload.tools:[];
      var toolLabels=tools.map(function(t){return TF_LABEL_MAP[t]||t;});
      var agents=Array.isArray(payload.agents)?payload.agents:[];
      var matrix=(payload.matrix&&typeof payload.matrix==="object")?payload.matrix:{};
      var wrap=document.getElementById("toolFreqWrap");
      if(!tools.length||!agents.length){wrap.innerHTML='<p class="text-sm text-ink-500 text-center py-8">No tool frequency data.</p>';return;}
      var ch=Math.max(400,tools.length*40);
      document.getElementById("toolFreqChart").parentElement.style.height=ch+"px";
      var datasets=agents.map(function(agent,i){var color=AGENT_COLORS[agent]||FALLBACK[i%FALLBACK.length];var data=tools.map(function(t){return Number((matrix[t]||{})[agent]||0);});var img=tfLogoImgs[agent];return{label:agent,data:data,backgroundColor:color+"cc",hoverBackgroundColor:color,borderColor:color,borderWidth:0,borderRadius:3,borderSkipped:false,barPercentage:0.75,categoryPercentage:0.7,pointStyle:img||"rectRounded"};});
      new Chart(document.getElementById("toolFreqChart"),{type:"bar",data:{labels:toolLabels,datasets:datasets},options:{indexAxis:"y",responsive:true,maintainAspectRatio:false,animation:{duration:800,easing:"easeOutQuart"},interaction:{mode:"index",intersect:false},plugins:{legend:{labels:{color:"#334155",usePointStyle:true,padding:16,font:{size:12,weight:"600"}}},tooltip:{backgroundColor:"rgba(15,23,42,0.92)",titleColor:"#f8fafc",bodyColor:"#e2e8f0",cornerRadius:10,padding:12,titleFont:{size:13,weight:"700"},bodyFont:{size:12}}},scales:{y:{ticks:{color:"#334155",font:{size:11,weight:"600"},padding:4},grid:{display:false},border:{display:false}},x:{beginAtZero:true,ticks:{color:"#94a3b8",font:{size:11},precision:0},grid:{color:"rgba(148,163,184,0.08)"},border:{display:false}}}}});
    }).catch(function(e){document.getElementById("toolFreqWrap").innerHTML='<p class="text-sm text-red-500 text-center py-8">'+((e&&e.message)||"Failed to load tool frequency data.")+'</p>';});
  });
})();
