<section class="mt-6 reveal rounded-[24px] border border-ink-200/60 bg-white/80 p-5 shadow-sm backdrop-blur-md">
  <form class="grid gap-4 sm:grid-cols-4" method="get">
    {% if auth_enabled %}
    <input type="hidden" name="tenant_id" value="{{ tenant }}"/>
    {% endif %}
    <label class="text-sm font-medium text-ink-700">
      agent_id
      <select name="agent_id" class="mt-1.5 w-full rounded-xl border border-ink-200 bg-white px-4 py-2.5 outline-none focus:ring-2 focus:ring-brand-500/50 transition-shadow">
        <option value="">(all)</option>
        {% for option in agent_options %}
        <option value="{{ option.value }}" {{ 'selected' if option.selected else '' }}>{{ option.label }}</option>
        {% endfor %}
      </select>
    </label>
    <label class="text-sm font-medium text-ink-700">
      days
      <input name="days" value="{{ days }}" class="mt-1.5 w-full rounded-xl border border-ink-200 bg-white px-4 py-2.5 outline-none focus:ring-2 focus:ring-brand-500/50 transition-shadow"/>
    </label>
    <div class="flex items-end">
      <button class="rounded-xl bg-ink-900 px-6 py-2.5 text-sm font-bold tracking-wide text-white transition-all hover:bg-ink-700 hover:shadow-md hover:-translate-y-0.5 w-full sm:w-auto" type="submit">Refresh</button>
    </div>
  </form>
</section>

<section class="mt-8 grid gap-5 sm:grid-cols-2 lg:grid-cols-3" id="perfMetricCards">
  <div class="flex items-center justify-center gap-2 py-8 text-ink-400"><span class="inline-block h-4 w-4 animate-spin rounded-full border-2 border-ink-300 border-t-ink-700"></span><span class="text-sm">Loading...</span></div>
</section>

<section class="mt-6 grid gap-6 lg:grid-cols-3">
  <div class="reveal rounded-[24px] border border-ink-200/60 bg-white/80 p-6 shadow-sm backdrop-blur-md lg:col-span-1">
    <h3 class="font-display text-xl font-bold tracking-tight text-ink-900">Performance Summary</h3>
    <div id="navSummary" class="mt-4 overflow-x-auto styled-scrollbar">
      <div class="flex items-center justify-center gap-2 py-8 text-ink-400"><span class="inline-block h-4 w-4 animate-spin rounded-full border-2 border-ink-300 border-t-ink-700"></span><span class="text-sm">Loading...</span></div>
    </div>
  </div>
  <div class="reveal rounded-[24px] border border-ink-200/60 bg-white/80 p-6 shadow-sm backdrop-blur-md lg:col-span-2">
    <div class="flex items-center justify-between mb-2">
      <h3 class="font-display text-lg font-bold tracking-tight text-ink-900">NAV Index</h3>
      <p class="text-[10px] font-medium uppercase tracking-widest text-ink-500">Baseline = 100 · TWR</p>
    </div>
    <div class="mt-3 h-[360px]" id="navChartWrap"><canvas id="navChart"></canvas></div>
  </div>
</section>

<section class="mt-8 grid gap-6 lg:grid-cols-2">
  <div class="reveal rounded-[24px] border border-ink-200/60 bg-white/80 p-6 shadow-sm backdrop-blur-md">
    <h3 class="font-display text-lg font-bold tracking-tight text-ink-900">Daily Tokens</h3>
    <div class="mt-3 h-[260px]" id="tokenDailyWrap"><canvas id="tokenDailyChart"></canvas></div>
  </div>
  <div class="reveal rounded-[24px] border border-ink-200/60 bg-white/80 p-6 shadow-sm backdrop-blur-md">
    <h3 class="font-display text-lg font-bold tracking-tight text-ink-900">Daily Trades</h3>
    <div class="mt-3 h-[260px]" id="tradeDailyWrap"><canvas id="tradeDailyChart"></canvas></div>
  </div>
</section>

<section class="mt-8 reveal rounded-[24px] border border-ink-200/60 bg-white/80 p-6 shadow-sm backdrop-blur-md">
  <h3 class="font-display text-xl font-bold tracking-tight text-ink-900 mb-5">Tool Call Frequency</h3>
  <div id="toolFreqWrap"><canvas id="toolFreqChart"></canvas></div>
</section>

