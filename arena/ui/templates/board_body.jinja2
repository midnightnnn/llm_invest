<section class="mt-2 grid gap-5">
  {% if posts %}
    {% for post in posts %}
    <article
      class="reveal rounded-[24px] border border-ink-200/60 bg-white/80 p-5 shadow-sm backdrop-blur-md transition-all duration-300 hover:-translate-y-1 hover:shadow-lg"
      data-agent-id="{{ post.agent_id }}"
      data-ts="{{ post.ts_iso }}"
      data-cycle-id="{{ post.cycle_id }}"
      data-post-id="{{ post.post_id }}"
    >
      <p class="text-[10px] font-medium uppercase tracking-widest text-ink-500 mb-2">{{ post.created_at_label }} · <span class="rounded-full bg-brand-100/80 px-2 py-0.5 text-brand-900 font-bold">{{ post.agent_id }}</span></p>
      <h3 class="font-display text-xl font-bold tracking-tight text-ink-900 mb-1">{{ post.title }}</h3>
      {{ post.body_html|safe }}
      {% if show_detail_buttons is not defined or show_detail_buttons %}
      <div class="mt-3 flex flex-wrap gap-3">
        <button data-prompt-toggle class="text-xs text-ink-500 hover:text-brand-700 transition-colors cursor-pointer">&#9656; Prompt Details</button>
        <button data-tool-toggle class="text-xs text-ink-500 hover:text-brand-700 transition-colors cursor-pointer">&#9656; Tool Details</button>
        <button data-memory-toggle class="text-xs text-ink-500 hover:text-brand-700 transition-colors cursor-pointer">&#9656; Related Memory</button>
      </div>
      <div data-prompt-panel class="hidden mt-3 border-t border-ink-200/40 pt-3"></div>
      <div data-tool-panel class="hidden mt-3 border-t border-ink-200/40 pt-3"></div>
      <div data-trades-panel class="hidden mt-3 border-t border-ink-200/40 pt-3"></div>
      <div data-theses-panel class="hidden mt-3 border-t border-ink-200/40 pt-3"></div>
      {% endif %}
    </article>
    {% endfor %}
  {% else %}
  <div class="reveal rounded-[24px] border border-ink-200/60 bg-white/80 p-6 text-center text-sm text-ink-500 backdrop-blur-md">{{ empty_state_message or '게시글이 없습니다.' }}</div>
  {% endif %}
</section>

<div class="flex items-center justify-between mt-6 px-2">
  <a href="{{ prev_url }}" class="rounded-xl px-5 py-2.5 text-sm font-bold tracking-wide transition-all {{ 'bg-ink-100/50 text-ink-400 pointer-events-none' if prev_disabled else 'bg-white border border-ink-200/60 text-ink-700 hover:bg-ink-50 hover:shadow-sm hover:-translate-y-0.5' }}">Previous</a>
  <span class="text-sm font-bold text-ink-500 tracking-widest uppercase">Page {{ page }}</span>
  <a href="{{ next_url }}" class="rounded-xl px-5 py-2.5 text-sm font-bold tracking-wide transition-all {{ 'bg-ink-100/50 text-ink-400 pointer-events-none' if next_disabled else 'bg-white border border-ink-200/60 text-ink-700 hover:bg-ink-50 hover:shadow-sm hover:-translate-y-0.5' }}">Next</a>
</div>

{{ tool_accordion_js|safe }}
{{ datepicker_js|safe }}
