<section class="overflow-hidden rounded-3xl border border-ink-200/70 bg-white/95 shadow-sm backdrop-blur-md">
  <div class="border-b border-ink-200/70 px-5 pt-4 pb-3">
    <div class="inline-flex rounded-full border border-slate-200 bg-slate-50/80 p-1">
      <button type="button" data-memory-tab="system" class="memory-tab-btn rounded-full bg-slate-900 px-4 py-1.5 text-xs font-semibold text-white transition-all">System</button>
      <button type="button" data-memory-tab="activity" class="memory-tab-btn rounded-full px-4 py-1.5 text-xs font-semibold text-slate-500 transition-all hover:bg-white hover:text-slate-700">Activity</button>
      <button type="button" data-memory-tab="network" class="memory-tab-btn rounded-full px-4 py-1.5 text-xs font-semibold text-slate-500 transition-all hover:bg-white hover:text-slate-700">Network</button>
    </div>
  </div>

  <div data-memory-tab-panel="system" class="p-4">
    <div class="grid gap-4 xl:grid-cols-[minmax(0,1fr)_280px]">
      <div class="min-w-0 rounded-2xl border border-ink-200/80 bg-white shadow-sm">
        <div class="flex items-center justify-between gap-3 border-b border-ink-200/80 px-5 py-3">
          <h2 class="text-sm font-bold text-ink-900">Memory System Map</h2>
          <span id="memory-save-status" class="hidden rounded-full border px-3 py-1 text-xs font-semibold transition-all"></span>
        </div>
        <div class="relative min-w-0 overflow-hidden rounded-b-2xl bg-gradient-to-br from-white via-slate-50/40 to-blue-50/30">
          <div id="memory-graph" class="h-[440px] w-full min-w-0 xl:h-[460px]"></div>
        </div>
      </div>

      <aside id="memory-panel" class="relative xl:sticky xl:top-24 xl:max-h-[calc(100vh-7rem)] xl:overflow-y-auto styled-scrollbar">
        <div id="memory-panel-loading" class="pointer-events-none absolute inset-0 z-20 hidden items-center justify-center rounded-2xl bg-white/70 backdrop-blur-[2px]">
          <div class="inline-flex items-center gap-2 rounded-full border border-slate-200 bg-white px-3 py-1.5 text-xs font-semibold text-slate-700 shadow-sm">
            <span class="inline-block h-3.5 w-3.5 animate-spin rounded-full border-2 border-slate-300 border-t-slate-700"></span>
            <span id="memory-panel-loading-text">저장 중...</span>
          </div>
        </div>

        <div class="overflow-hidden rounded-2xl border border-slate-200/60 bg-white shadow-sm">
          <div id="memory-panel-header" class="px-5 pb-4 pt-5">
            <div id="memory-panel-breadcrumb"></div>
            <div class="flex items-center gap-2">
              <span id="memory-panel-dot" class="h-2 w-2 rounded-full bg-cyan-500 transition-colors"></span>
              <h3 id="memory-panel-title" class="text-base font-bold text-slate-900">{{ initial_title }}</h3>
            </div>
            <p id="memory-panel-desc" class="hidden mt-2 text-sm leading-relaxed text-slate-500"></p>
          </div>
          <div class="h-px bg-slate-200/80"></div>
          <div id="memory-panel-form" class="px-5 py-4">
            <div class="py-2"></div>
          </div>
        </div>
      </aside>
    </div>
  </div>

  <div data-memory-tab-panel="activity" class="hidden p-4">
    <div id="memory-activity-content" class="space-y-4"></div>
  </div>

  <div data-memory-tab-panel="network" class="hidden p-4">
    <div class="grid gap-4 xl:grid-cols-[minmax(0,1fr)_300px]">
      <div class="min-w-0 rounded-2xl border border-ink-200/80 bg-white shadow-sm">
        <div class="border-b border-ink-200/80 px-5 py-3">
          <div class="flex flex-wrap items-end gap-3">
            <label class="min-w-[88px]">
              <span class="text-xs font-medium text-slate-500">기간</span>
              <select id="memory-network-days" class="mt-1 w-full rounded-lg border border-ink-200 bg-white px-3 py-1.5 text-sm text-ink-700 outline-none focus:ring-2 focus:ring-brand-500/40">
                <option value="7">7일</option>
                <option value="30" selected>30일</option>
                <option value="90">90일</option>
              </select>
            </label>
            <label class="min-w-[110px] flex-1">
              <span class="text-xs font-medium text-slate-500">Agent</span>
              <select id="memory-network-agent" class="mt-1 w-full rounded-lg border border-ink-200 bg-white px-3 py-1.5 text-sm text-ink-700 outline-none focus:ring-2 focus:ring-brand-500/40">
                <option value="">전체</option>
              </select>
            </label>
            <label class="min-w-[110px] flex-1">
              <span class="text-xs font-medium text-slate-500">Event</span>
              <select id="memory-network-event" class="mt-1 w-full rounded-lg border border-ink-200 bg-white px-3 py-1.5 text-sm text-ink-700 outline-none focus:ring-2 focus:ring-brand-500/40">
                <option value="">전체</option>
              </select>
            </label>
            <label class="min-w-[110px] flex-1">
              <span class="text-xs font-medium text-slate-500">Ticker</span>
              <input id="memory-network-ticker" type="text" placeholder="AAPL" class="mt-1 w-full rounded-lg border border-ink-200 bg-white px-3 py-1.5 text-sm uppercase text-ink-700 outline-none focus:ring-2 focus:ring-brand-500/40"/>
            </label>
            <label class="inline-flex items-center gap-2 rounded-lg border border-slate-200 bg-slate-50 px-3 py-1.5 text-xs font-medium text-slate-600">
              <input id="memory-network-prompt-only" type="checkbox" class="h-3.5 w-3.5 rounded border-slate-300 text-cyan-600 focus:ring-cyan-500/40"/>
              <span>프롬프트만</span>
            </label>
            <button id="memory-network-refresh" type="button" class="rounded-lg bg-slate-900 px-4 py-1.5 text-xs font-semibold text-white transition-all hover:bg-slate-800">새로고침</button>
          </div>
        </div>
        <div class="relative min-w-0 overflow-hidden rounded-b-2xl bg-gradient-to-br from-white via-slate-50/30 to-blue-50/20">
          <div id="memory-network-graph" class="h-[440px] w-full min-w-0 xl:h-[480px]"></div>
        </div>
      </div>

      <aside class="overflow-hidden rounded-2xl border border-slate-200/60 bg-white shadow-sm">
        <div class="border-b border-slate-200/80 px-5 py-4">
          <h3 class="text-sm font-bold text-slate-900">Memory Network</h3>
        </div>
        <div id="memory-network-panel" class="px-4 py-4"></div>
      </aside>
    </div>
  </div>
</section>

<script id="memory-graph-payload" type="application/json">{{ graph_payload_json|safe }}</script>
<script src="/assets/vendor/three.min.js"></script>
<script src="/assets/vendor/3d-force-graph.min.js"></script>
<script>
{% include "memory_panel_script.jinja2" %}
</script>
